<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
  </head>
  <body>
    <header><h1><%= title %></h1></header>
    <%- include("partials/category", {
          name: "Authors",
          shownCategories: shownAuthors,
          pages: authorsPages,
          query
        }) 
    %>

    <% if (query.showAuthorForm) { %>
      <%- include("partials/form", {
        name: "author",
        fields: [
          {name: "name", type: "text"}
        ]
      }) %>
    <% } %>

    <%- include("partials/category", {
      name: "Genres",
      shownCategories: shownGenres,
      pages: genresPages,
      query
    })
    %>

    <% if (query.showGenreForm) { %>
      <%- include("partials/form", {
        name: "genre",
        fields: [
          {name: "name", type: "text"}
        ]
      })
      %>
    <% } %>

    <%- include("partials/category", {
      name: "Publishers",
      shownCategories: shownPublishers,
      pages: publishersPages,
      query
    })
    %>

    <% if (query.showPublisherForm) { %>
      <%- include("partials/form", {
        name: "publisher",
        fields: [
          {name: "name", type: "text"}
        ]
      })
      %>
    <% } %>
  </body>
</html>
